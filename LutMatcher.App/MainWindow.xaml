<Window x:Class="LutMatcher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LutMatcher.App"
        mc:Ignorable="d"
        Title="LUT Matcher" Height="840" Width="1400">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
            <Button Content="Load Reference" Command="{Binding LoadReferenceCommand}" Margin="0 0 8 0" />
            <Button Content="Load Target" Command="{Binding LoadTargetCommand}" Margin="0 0 8 0" />
            <Button Content="Load Ref Camera" Command="{Binding LoadReferenceCameraCommand}" Margin="0 0 8 0" />
            <Button Content="Load Target Camera" Command="{Binding LoadTargetCameraCommand}" Margin="0 0 8 0" />
            <Button Content="Auto Fit LUT" Command="{Binding AutoFitCommand}" Margin="0 0 8 0" />
            <Button Content="Export LUT" Command="{Binding ExportCommand}" Margin="0 0 8 0" />
            <Button Content="Reset" Command="{Binding ResetCommand}" Margin="0 0 8 0" />
            <Button Content="Cancel" Command="{Binding CancelCommand}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Reference" Grid.Column="0" Margin="4">
                <Image Source="{Binding ReferencePreview}" Stretch="Uniform"/>
            </GroupBox>
            <GroupBox Header="Target" Grid.Column="1" Margin="4">
                <Image Source="{Binding TargetPreview}" Stretch="Uniform"/>
            </GroupBox>
            <GroupBox Header="Corrected" Grid.Column="2" Margin="4">
                <Image Source="{Binding CorrectedPreview}" Stretch="Uniform"/>
            </GroupBox>
            <GroupBox Header="Diff" Grid.Column="3" Margin="4">
                <Image Source="{Binding DiffPreview}" Stretch="Uniform"/>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Options" Margin="4">
                <StackPanel Margin="8">
                    <TextBlock Text="Range" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0 2 0 8">
                        <RadioButton Content="Full range" IsChecked="{Binding IsFullRange}" Margin="0 0 16 0"/>
                        <RadioButton Content="Video range" IsChecked="{Binding IsVideoRange}"/>
                    </StackPanel>

                    <TextBlock Text="LUT Size" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding LutSizes}" SelectedItem="{Binding SelectedLutSize}" Width="100" Margin="0 2 0 8"/>

                    <TextBlock Text="ROI (x, y, width, height)" FontWeight="SemiBold"/>
                    <UniformGrid Rows="2" Columns="4" Margin="0 2 0 0">
                        <TextBlock Text="X"/>
                        <TextBlock Text="Y"/>
                        <TextBlock Text="W"/>
                        <TextBlock Text="H"/>
                        <TextBox Text="{Binding RoiX}" Margin="0 2 4 0"/>
                        <TextBox Text="{Binding RoiY}" Margin="0 2 4 0"/>
                        <TextBox Text="{Binding RoiW}" Margin="0 2 4 0"/>
                        <TextBox Text="{Binding RoiH}" Margin="0 2 4 0"/>
                    </UniformGrid>
                    <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                        <Button Content="Apply ROI" Command="{Binding ApplyRoiCommand}" Margin="0 0 8 0" />
                        <Button Content="Clear ROI" Command="{Binding ClearRoiCommand}" />
                    </StackPanel>

                    <CheckBox Content="Enable Auto Align" IsChecked="{Binding EnableAutoAlign}" Margin="0 8 0 0"/>

                    <DockPanel Margin="0 8 0 0">
                        <TextBlock Text="Camera device" FontWeight="SemiBold" />
                        <Button Content="Refresh" Command="{Binding RefreshCameraListCommand}" Margin="8 0 0 0" Padding="8 1" />
                    </DockPanel>
                    <UniformGrid Rows="2" Columns="2" Margin="0 2 0 0">
                        <TextBlock Text="Reference"/>
                        <TextBlock Text="Target"/>
                        <ComboBox ItemsSource="{Binding CameraOptions}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedReferenceCamera}" Margin="0 2 4 0"/>
                        <ComboBox ItemsSource="{Binding CameraOptions}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedTargetCamera}" Margin="0 2 4 0"/>
                    </UniformGrid>

                    <TextBlock Text="Frame delay (frames)" FontWeight="SemiBold" Margin="0 8 0 0"/>
                    <UniformGrid Rows="2" Columns="2" Margin="0 2 0 0">
                        <TextBlock Text="Reference"/>
                        <TextBlock Text="Target"/>
                        <TextBox Text="{Binding ReferenceFrameDelay}" Margin="0 2 4 0"/>
                        <TextBox Text="{Binding TargetFrameDelay}" Margin="0 2 4 0"/>
                    </UniformGrid>
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Log / Metrics" Margin="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border BorderBrush="#808080" BorderThickness="1" CornerRadius="2" Margin="0 0 0 6" Padding="6">
                        <TextBlock Text="{Binding MetricsText}" FontFamily="Consolas"/>
                    </Border>
                    <TextBox Grid.Row="1" Text="{Binding LogText}" FontFamily="Consolas" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
